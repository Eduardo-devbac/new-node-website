<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/static/styles/estilos.css" />
    <script src="/static/js/config.js" defer></script>
    <script src="/static/js/functions.js" defer></script>
    <title>Panel de administrador</title>
</head>

<body>
    <header class="header">
        <nav class="menu">
            <%- include("../partials/navbar") %>
        </nav>
    </header>

    <main class="admin-container">
        <h1 class="admin-title">Panel de administración</h1>
        <h2 class="admin-subtitle">Bienvenido, <%= user.name %></h2>

        <div class="table-container">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Correo</th>
                        <th>Modalidad</th>
                        <th>Rol</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
  <% if (usuarios) { %>

    <% for (let i = 0; i < usuarios.length; i++) { %>
      <tr>
        <td><%= usuarios[i].id_users %></td>
        <td><%= usuarios[i].name %></td>
        <td><%= usuarios[i].mail %></td>
        <td><%= usuarios[i].modality %></td>
        <td><%= usuarios[i].rol %></td>
        <td>
             <button class="btn-action btn-danger delete-user" data-id="<%= usuarios[i].id_users %>" id="delete-user">Eliminar</button>
        </td>
      </tr>
    <% } %>

  <% } else { %>
      <tr>
        <td colspan="5" style="text-align:center; padding: 20px;">
          No hay usuarios registrados
        </td>
      </tr>
  <% } %>
</tbody>
            </table>
        </div>
    </main>
</body>
</html>